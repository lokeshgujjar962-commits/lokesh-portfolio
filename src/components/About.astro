<style>
  .about-section {
    padding: 4rem 2rem;
    display: flex;
    justify-content: center;
  }

  .about-container {
    max-width: 900px;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .avatar-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .avatar-placeholder {
    width: 300px;
    height: 300px;
    border-radius: 20px;
    overflow: hidden;
    /* Simulate the rough/hand-drawn edge */
    mask-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><path d="M 5,5 Q 50,0 95,5 Q 100,50 95,95 Q 50,100 5,95 Q 0,50 5,5 Z" fill="black"/></svg>');
    -webkit-mask-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><path d="M 5,5 C 20,0 80,0 95,5 C 100,20 100,80 95,95 C 80,100 20,100 5,95 C 0,80 0,20 5,5 Z" fill="black"/></svg>');
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
    box-shadow: -10px 10px 0px rgba(0,0,0,0.05);
  }

  .color-palette {
    display: flex;
    gap: 0.5rem;
  }

  .color-swatch {
    width: 25px;
    height: 25px;
    border-radius: 4px;
    box-shadow: 2px 2px 0 rgba(0,0,0,0.1);
  }

  .about-content {
    flex: 1.5;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .about-title {
    font-size: 2.5rem;
    transform: rotate(-3deg);
    padding: 10px 40px;
    margin-bottom: 0.5rem;
  }

  .about-text {
    font-size: 1.1rem;
    color: var(--color-dark-blue);
    line-height: 1.8;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.2rem;
    font-weight: bold;
    transition: transform 0.2s;
  }

  .social-item:hover {
    transform: translateX(10px);
  }

  .icon-placeholder {
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .icon-placeholder svg {
    width: 30px;
    height: 30px;
  }

  .youtube { color: #d9534f; }
  .instagram { color: #5bc0de; }
  .email { color: #5cb85c; }

  @media (max-width: 768px) {
    .about-container {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .about-content {
      align-items: center;
    }
    .about-text {
      text-align: center;
    }
  }
</style>

---
---
<section class="hero-section" id="hero">
  <div class="hero-top">
    <p class="greeting">👋, my name is Prem and I am an IMCA student</p>
  </div>

  <div class="hero-main">
    <div class="title-container">
      <h1 class="title-solid">Webdeveloper</h1>
      <h1 class="title-outline">& Programmer</h1>
    </div>

    <!-- Center Cutout Image Placeholder -->
   
  </div>

  <div class="hero-bottom">
    <p class="location">based in India.</p>
    
    <div class="logos-placeholder">
      <span class="logo-text">React</span>
      <span class="logo-text">Node</span>
      <span class="logo-text">Astro</span>
      <span class="logo-text">Python</span>
    </div>
  </div>

  <div class="hero-actions">
    <a href="#contact" class="btn action-btn">Hire a developer</a>
    <a href="#projects" class="btn btn-outline action-btn">View projects</a>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 7rem 4rem 2rem;
    overflow: hidden;
  }

  .hero-top {
    margin-bottom: 2rem;
    z-index: 2;
  }

  .greeting {
    font-size: 1.2rem;
    color: #555;
  }

  .hero-main {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 4rem;
  }

  .title-container {
    text-align: center;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .title-solid {
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.9;
    color: #000;
    margin: 0;
  }

  .title-outline {
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 1px #000;
    margin: 0;
  }

  .center-portrait {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(200px, 25vw, 300px);
    height: clamp(250px, 30vw, 400px);
    border-radius: 120px 120px 0 0; /* Dome shape like the example */
    overflow: hidden;
    z-index: 2;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }

  .portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%); /* B&W effect to match the theme */
  }

  .hero-bottom {
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-width: 1000px;
    align-items: center;
    margin-bottom: 3rem;
    z-index: 2;
  }

  .location {
    font-size: 1.2rem;
    color: #555;
  }

  .logos-placeholder {
    display: flex;
    gap: 2rem;
    opacity: 0.4;
  }

  .logo-text {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-style: italic;
    font-size: 1.1rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    z-index: 2;
  }

  .action-btn {
    padding: 15px 30px;
    font-size: 1.1rem;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 2rem 1.5rem;
    }
    
    .center-portrait {
      opacity: 0.8; /* Make it slightly transparent on mobile so text is readable */
    }

    .hero-bottom {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
    
    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
  }
</style>

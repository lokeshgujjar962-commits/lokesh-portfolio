---
---
<section class="hero-section" id="hero">
  <div class="collage-container">
    <!-- Placeholder shapes for collage elements -->
    <div class="collage-piece cp-1"></div>
    <div class="collage-piece cp-2"></div>
    <div class="collage-piece cp-3"></div>
    <div class="collage-piece cp-4"></div>
    
    <div class="hero-title-container">
      <h1 class="hero-title">PORTFOLIO</h1>
      <div class="pill name-pill">DAVID THIO</div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 80vh;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 2rem;
    overflow: visible;
  }

  .collage-container {
    position: relative;
    width: 100%;
    max-width: 800px;
    height: 500px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Placeholder collage pieces with torn-paper look */
  .collage-piece {
    position: absolute;
    background-color: var(--color-teal);
    border-radius: 10px;
    box-shadow: 2px 4px 10px rgba(0,0,0,0.1);
  }

  .cp-1 {
    width: 250px;
    height: 180px;
    top: 5%;
    left: 10%;
    transform: rotate(-5deg);
    background-color: #f7a072;
    clip-path: polygon(0% 0%, 100% 5%, 95% 100%, 5% 95%);
  }

  .cp-2 {
    width: 280px;
    height: 200px;
    top: 0%;
    right: 5%;
    transform: rotate(3deg);
    background-color: #e26d5c;
    clip-path: polygon(5% 0%, 100% 0%, 95% 100%, 0% 95%);
  }

  .cp-3 {
    width: 300px;
    height: 200px;
    bottom: -10%;
    left: 5%;
    transform: rotate(2deg);
    background-color: #72b01d;
    clip-path: polygon(0% 5%, 95% 0%, 100% 95%, 5% 100%);
  }

  .cp-4 {
    width: 320px;
    height: 220px;
    bottom: -15%;
    right: 5%;
    transform: rotate(-4deg);
    background-color: #3f7d20;
    clip-path: polygon(5% 5%, 100% 0%, 95% 95%, 0% 100%);
  }

  .hero-title-container {
    position: relative;
    z-index: 10;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: rotate(-2deg);
  }

  .hero-title {
    font-size: 7rem;
    color: var(--color-dark-blue);
    margin: 0;
    line-height: 1;
    /* Thick white outline simulating sticker effect */
    text-shadow: 
      -4px -4px 0 #fff, 4px -4px 0 #fff, 
      -4px 4px 0 #fff, 4px 4px 0 #fff,
      -8px 0px 0 #fff, 8px 0px 0 #fff,
      0px -8px 0 #fff, 0px 8px 0 #fff,
      -5px -5px 15px rgba(0,0,0,0.1);
    letter-spacing: -2px;
  }

  .name-pill {
    background-color: #8ACDD8;
    color: #fff;
    font-size: 1.5rem;
    padding: 8px 30px;
    border-radius: 50px;
    margin-top: -15px;
    z-index: 11;
    border: 4px solid #fff;
    box-shadow: 0px 4px 0px rgba(0,0,0,0.1);
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 4rem;
    }
    .collage-container {
      height: 300px;
    }
  }
</style>

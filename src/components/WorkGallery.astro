---
---
<section class="projects-section" id="projects">
  <div class="projects-header">
    <h2 class="section-title">Selected Works</h2>
    <p class="section-subtitle">A collection of my recent web development projects.</p>
  </div>

  <div class="projects-grid">
    <!-- Project 1 -->
    <a href="#" class="project-card">
      <div class="project-image">
        <div class="placeholder-img">React</div>
      </div>
      <div class="project-info">
        <h3 class="project-name">E-Commerce Platform</h3>
        <p class="project-tech">React & Node.js</p>
      </div>
      <div class="project-arrow">↗</div>
    </a>

    <!-- Project 2 -->
    <a href="#" class="project-card">
      <div class="project-image">
        <div class="placeholder-img">Python</div>
      </div>
      <div class="project-info">
        <h3 class="project-name">Data Analytics Dashboard</h3>
        <p class="project-tech">Python & Django</p>
      </div>
      <div class="project-arrow">↗</div>
    </a>

    <!-- Project 3 -->
    <a href="#" class="project-card">
      <div class="project-image">
        <div class="placeholder-img">Astro</div>
      </div>
      <div class="project-info">
        <h3 class="project-name">Minimalist Portfolio</h3>
        <p class="project-tech">Astro & CSS</p>
      </div>
      <div class="project-arrow">↗</div>
    </a>
  </div>
</section>

<style>
  .projects-section {
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-header {
    margin-bottom: 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 2px solid #000;
    padding-bottom: 1rem;
  }

  .section-title {
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: #666;
    max-width: 300px;
    text-align: right;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-card {
    display: flex;
    align-items: center;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: padding 0.3s ease, background-color 0.3s ease;
    group: project;
  }

  .project-card:hover {
    padding-left: 2rem;
    padding-right: 2rem;
    background-color: #f9f9f9;
  }

  .project-image {
    width: 150px;
    height: 100px;
    border-radius: 4px;
    overflow: hidden;
    margin-right: 3rem;
    flex-shrink: 0;
  }

  .placeholder-img {
    width: 100%;
    height: 100%;
    background-color: #eee;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    color: #ccc;
    font-size: 1.5rem;
    transition: transform 0.5s ease;
  }

  .project-card:hover .placeholder-img {
    transform: scale(1.05);
    background-color: #000;
    color: #fff;
  }

  .project-info {
    flex-grow: 1;
  }

  .project-name {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease;
  }

  .project-tech {
    font-size: 1rem;
    color: #666;
  }

  .project-arrow {
    font-size: 2rem;
    font-weight: 300;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.3s ease;
  }

  .project-card:hover .project-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 4rem 1.5rem;
    }
    
    .projects-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    
    .section-subtitle {
      text-align: left;
    }
    
    .project-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    
    .project-card:hover {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    
    .project-image {
      width: 100%;
      height: 200px;
      margin-right: 0;
    }
    
    .project-arrow {
      display: none;
    }
  }
</style>

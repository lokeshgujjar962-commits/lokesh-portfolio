---
<section class="gallery-section" id="gallery">
  <div class="gallery-container">
    
    <div class="gallery-title-container">
      <h2 class="gallery-title">E-MONEY</h2>
    </div>

    <div class="cards-container">
      <!-- Placeholder Cards -->
      <div class="gallery-card card-1">
        <div class="card-inner">
          <div class="card-content">
            <span class="card-text">Design 1</span>
          </div>
        </div>
      </div>
      <div class="gallery-card card-2">
        <div class="card-inner">
          <div class="card-content">
            <span class="card-text">Design 2</span>
          </div>
        </div>
      </div>
      <div class="gallery-card card-3">
        <div class="card-inner">
          <div class="card-content">
            <span class="card-text">Design 3</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .gallery-section {
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .gallery-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .gallery-title-container {
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 10;
  }

  .gallery-title {
    font-size: 5rem;
    color: var(--color-dark-blue);
    margin: 0;
    line-height: 1;
    /* Thick white outline simulating sticker effect */
    text-shadow: 
      -3px -3px 0 #fff, 3px -3px 0 #fff, 
      -3px 3px 0 #fff, 3px 3px 0 #fff,
      -6px 0px 0 #fff, 6px 0px 0 #fff,
      0px -6px 0 #fff, 0px 6px 0 #fff,
      -4px -4px 10px rgba(0,0,0,0.1);
  }

  .cards-container {
    display: flex;
    gap: 2rem;
    perspective: 1000px;
    margin-left: auto;
    padding: 4rem;
  }

  .gallery-card {
    width: 280px;
    height: 180px;
    border-radius: 15px;
    position: relative;
    transform-style: preserve-3d;
    box-shadow: -15px 15px 20px rgba(0,0,0,0.15);
    background-color: var(--color-teal);
    transition: transform 0.3s ease;
  }

  .gallery-card:hover {
    transform: translateY(-10px) rotateX(10deg) rotateY(-5deg) !important;
  }

  .card-inner {
    width: 100%;
    height: 100%;
    border-radius: 15px;
    overflow: hidden;
    border: 3px solid #fff;
    background: linear-gradient(135deg, #8ACDD8, #1D3A5F);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .card-1 {
    transform: rotateX(20deg) rotateY(-15deg) rotateZ(5deg);
    z-index: 1;
  }
  
  .card-2 {
    transform: rotateX(25deg) rotateY(-20deg) rotateZ(10deg) translateY(-20px);
    z-index: 2;
    background-color: #f7a072;
    .card-inner { background: linear-gradient(135deg, #f7a072, #e26d5c); }
  }

  .card-3 {
    transform: rotateX(15deg) rotateY(-10deg) rotateZ(0deg) translateY(20px);
    z-index: 3;
    background-color: #72b01d;
    .card-inner { background: linear-gradient(135deg, #72b01d, #3f7d20); }
  }

  .card-text {
    font-family: 'Shrikhand', cursive;
    color: white;
    font-size: 2rem;
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .gallery-container {
      flex-direction: column;
      align-items: center;
    }
    .cards-container {
      margin-left: 0;
      flex-direction: column;
      perspective: none;
      padding: 2rem 0;
    }
    .gallery-card {
      transform: none !important;
      margin-bottom: 2rem;
    }
    .gallery-title-container {
      position: relative;
      margin-top: 2rem;
    }
  }
</style>

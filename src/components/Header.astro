---
---

<header class="header">
  <nav class="navbar-pill" id="navbar-pill">

    <!-- Aurora glow that follows mouse -->
    <div class="nav-aurora" id="nav-aurora"></div>

    <!-- Bubbles container (outside pill so they can float above) -->
    <div class="nav-bubbles" id="nav-bubbles"></div>

    <div class="logo">
      <a href="/">Prem<span class="dot">.</span></a>
    </div>

    <ul class="nav-links" id="nav-links">
      <li class="nav-item">
        <a href="#design" class="nav-link active">Design</a>
      </li>
      <li class="nav-item">
        <a href="#projects" class="nav-link">Projects</a>
      </li>
      <li class="nav-item">
        <a href="#about" class="nav-link">About</a>
      </li>
      <li class="nav-item nav-lang">
        <a href="#" class="nav-link lang">EN</a>
      </li>
    </ul>

    <div class="contact">
      <a href="mailto:hello@prem.in" class="btn-pill">hello@prem.in</a>
    </div>

  </nav>
</header>

<style>
  /* ── Outer header wrapper ── */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    display: flex;
    justify-content: center;
    padding: 1.2rem 1rem;
    pointer-events: none;
  }

  /* ── Pill ── */
  .navbar-pill {
    pointer-events: all;
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(220, 220, 255, 0.55);
    border-radius: 999px;
    padding: 0.45rem 0.55rem 0.45rem 1.4rem;
    box-shadow:
      0 4px 32px rgba(0, 0, 0, 0.07),
      0 1px 3px rgba(0, 0, 0, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    max-width: 680px;
    width: 100%;
    /* Allow bubbles to float ABOVE the pill */
    overflow: visible;
  }

  /* ── Aurora glow (follows mouse within nav) ── */
  .nav-aurora {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 160px;
    height: 160px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    background: radial-gradient(
      circle,
      rgba(100, 120, 255, 0.38) 0%,
      rgba(130, 100, 255, 0.22) 35%,
      rgba(180, 150, 255, 0.1) 60%,
      transparent 80%
    );
    filter: blur(18px);
    transition:
      left 0.25s cubic-bezier(0.23, 1, 0.32, 1),
      opacity 0.3s ease;
    will-change: left, opacity;
  }

  .navbar-pill:hover .nav-aurora,
  .navbar-pill.aurora-active .nav-aurora {
    opacity: 1;
  }

  /* ── Bubbles layer — sits outside pill, above it ── */
  .nav-bubbles {
    position: absolute;
    /* Extend above the pill */
    top: -120px;
    left: 0;
    width: 100%;
    height: calc(100% + 120px);
    pointer-events: none;
    z-index: 10;
    overflow: hidden;
  }

  /* Individual bubble */
  .nav-bubbles .bbl {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    animation: bbl-rise var(--dur, 2.2s) cubic-bezier(0.2, 0.6, 0.4, 1) var(--delay, 0s) both;
    background: radial-gradient(
      circle at 32% 28%,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(160, 180, 255, 0.45) 40%,
      rgba(100, 130, 255, 0.15) 70%,
      transparent 100%
    );
    border: 1px solid rgba(140, 160, 255, 0.35);
    box-shadow:
      inset 2px 2px 5px rgba(255, 255, 255, 0.7),
      inset -1px -1px 4px rgba(80, 110, 255, 0.2),
      0 2px 8px rgba(80, 110, 255, 0.1);
  }

  @keyframes bbl-rise {
    0% {
      transform: translateY(0) translateX(0) scale(0.3);
      opacity: 0;
    }
    12% {
      opacity: 0.85;
    }
    75% {
      opacity: 0.55;
    }
    100% {
      transform: translateY(calc(-90px + var(--rise, -50px))) translateX(var(--drift, 0px)) scale(0.95);
      opacity: 0;
    }
  }

  /* ── Logo ── */
  .logo {
    flex-shrink: 0;
    margin-right: 1.6rem;
    position: relative;
    z-index: 2;
  }

  .logo a {
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.05em;
    color: #111;
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .dot {
    color: #ff3366;
  }

  /* ── Nav Links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    position: relative;
    z-index: 2;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 1.05rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    border-radius: 999px;
    transition: color 0.22s ease;
    cursor: pointer;
    white-space: nowrap;
    z-index: 2;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #3b4cff;
    font-weight: 600;
    opacity: 1;
  }

  /* Active pulsing dot indicator below */
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #3b4cff;
    box-shadow: 0 0 0 0 rgba(59, 76, 255, 0.5);
    animation: dot-ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes dot-ping {
    0%   { box-shadow: 0 0 0 0 rgba(59, 76, 255, 0.55); }
    70%  { box-shadow: 0 0 0 8px rgba(59, 76, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(59, 76, 255, 0); }
  }

  /* Lang */
  .nav-lang { margin-left: 0.3rem; }

  .nav-link.lang {
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.03em;
    color: #444;
  }

  .nav-link.lang:hover { color: #3b4cff; }

  /* ── CTA ── */
  .contact {
    margin-left: 1rem;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .btn-pill {
    display: inline-flex;
    align-items: center;
    background-color: #111;
    color: #fff;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.62rem 1.35rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.22s ease, transform 0.18s ease, box-shadow 0.22s ease;
    position: relative;
    overflow: hidden;
  }

  .btn-pill:hover {
    background-color: #222;
    transform: translateY(-1px);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.18);
    opacity: 1;
  }

  .btn-pill:active {
    transform: translateY(0);
    background-color: #3b4cff;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .navbar-pill { padding: 0.4rem 0.4rem 0.4rem 1rem; }
    .logo { margin-right: 0.8rem; }
    .nav-link { padding: 0.4rem 0.6rem; font-size: 0.82rem; }
    .btn-pill { font-size: 0.78rem; padding: 0.5rem 0.9rem; }
  }
</style>

<script>
  const pill     = document.getElementById('navbar-pill') as HTMLElement;
  const aurora   = document.getElementById('nav-aurora') as HTMLElement;
  const bubblesEl= document.getElementById('nav-bubbles') as HTMLElement;
  const navLinks = document.getElementById('nav-links') as HTMLElement;

  if (!pill || !aurora || !bubblesEl) throw new Error('Header elements missing');

  /* ── Track mouse over the pill and move the aurora glow ── */
  let auroraX = pill.offsetWidth / 2;
  let targetX = auroraX;
  let animFrame: number;
  let isHovering = false;

  pill.addEventListener('mouseenter', () => {
    isHovering = true;
    pill.classList.add('aurora-active');
  });

  pill.addEventListener('mouseleave', () => {
    isHovering = false;
    pill.classList.remove('aurora-active');
    aurora.style.opacity = '0';
  });

  pill.addEventListener('mousemove', (e: MouseEvent) => {
    const rect = pill.getBoundingClientRect();
    // X position relative to the pill
    targetX = e.clientX - rect.left;
  });

  // Smooth lerp animation for aurora
  function lerpAurora() {
    if (isHovering) {
      // Smoothly chase the mouse X
      auroraX += (targetX - auroraX) * 0.12;
      aurora.style.left = `${auroraX}px`;
      aurora.style.top = '50%';
      aurora.style.transform = 'translate(-50%, -50%)';
    }
    animFrame = requestAnimationFrame(lerpAurora);
  }
  lerpAurora();

  /* ── Spawn bubbles at mouse position while hovering nav ── */
  let lastBubbleTime = 0;
  const BUBBLE_INTERVAL = 220; // ms between bubbles

  pill.addEventListener('mousemove', (e: MouseEvent) => {
    const now = Date.now();
    if (now - lastBubbleTime < BUBBLE_INTERVAL) return;
    lastBubbleTime = now;

    const pillRect = pill.getBoundingClientRect();
    // X relative to pill
    const relX = e.clientX - pillRect.left;
    // Spawn near bottom of pill (so they float upward through it)
    const startY = pillRect.height;

    spawnBubble(relX, startY);
  });

  function spawnBubble(x: number, startY: number) {
    const bbl = document.createElement('div');
    bbl.className = 'bbl';

    const size   = 5 + Math.random() * 14;          // 5–19px
    const dur    = (1.5 + Math.random() * 1.8).toFixed(2); // 1.5–3.3s
    const delay  = (Math.random() * 0.2).toFixed(2);
    const drift  = ((Math.random() - 0.5) * 22).toFixed(1); // ±11px horizontal
    const rise   = -(50 + Math.random() * 60);       // how far above pill

    // Center bubble on the cursor x, within the bubble container
    const bx = x - size / 2;
    // Start at bottom of the container's visible pill region
    const by = startY - size / 2;

    bbl.style.cssText = `
      width:${size}px;
      height:${size}px;
      left:${bx}px;
      top:${by}px;
      --dur:${dur}s;
      --delay:${delay}s;
      --drift:${drift}px;
      --rise:${rise}px;
    `;

    bubblesEl.appendChild(bbl);
    const totalMs = (parseFloat(dur) + parseFloat(delay)) * 1000 + 100;
    setTimeout(() => bbl.remove(), totalMs);
  }

  /* ── Click: update active link ── */
  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', function () {
      document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
      (this as HTMLElement).classList.add('active');
    });
  });
</script>

<style is:global>
  /* Prevent body top overlap with fixed pill nav */
  .hero-section {
    padding-top: 6rem !important;
  }
</style>

---
---
<footer class="footer-section" id="contact">
  <div class="footer-container">
    
    <div class="footer-top">
      <h2 class="lets-talk" data-gsap="fade-up">Let's Talk.</h2>
      <a href="mailto:premshankar@example.com" class="email-link" data-gsap="fade-up" data-delay="0.1">premshankar@example.com</a>
    </div>

    <div class="footer-bottom">
      <div class="social-links" data-gsap="fade-in" data-delay="0.2">
        <a href="#" class="social-item">LinkedIn</a>
        <a href="#" class="social-item">GitHub</a>
        <a href="#" class="social-item">Twitter</a>
      </div>
      
      <div class="copyright" data-gsap="fade-in" data-delay="0.3">
        <p>&copy; {new Date().getFullYear()} Prem Shankar. All rights reserved.</p>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer-section {
    padding: 8rem 4rem 4rem 4rem;
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .lets-talk {
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    color: #000;
  }

  .email-link {
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: #666;
    text-decoration: underline;
    text-underline-offset: 8px;
    transition: color 0.3s ease;
  }

  .email-link:hover {
    color: #000;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid #eaeaea;
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .social-item {
    font-weight: 500;
    color: #000;
    font-size: 1.1rem;
    position: relative;
  }

  .social-item::after {
    content: '';
    position: absolute;
    width: 0;
    height: 1px;
    bottom: -2px;
    left: 0;
    background-color: #000;
    transition: width 0.3s ease;
  }

  .social-item:hover::after {
    width: 100%;
  }

  .copyright {
    color: #888;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .footer-section {
      padding: 4rem 1.5rem 2rem 1.5rem;
    }
    
    .footer-container {
      gap: 4rem;
    }
    
    .footer-bottom {
      flex-direction: column;
      gap: 2rem;
      align-items: flex-start;
    }
  }
</style>
